<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!-- Checkstyle — limiares do padrao-escrita (ecossistema Sarak).
     Uso: checkstyle -c checkstyle.xml src/  (ou plugin Maven/Gradle) -->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <module name="TreeWalker">
    <!-- Limiares objetivos -->
    <module name="MethodLength">
      <property name="max" value="40"/>          <!-- função <= 40 linhas -->
    </module>
    <module name="ParameterNumber">
      <property name="max" value="4"/>           <!-- <= 4 parametros -->
    </module>
    <module name="NestedIfDepth">
      <property name="max" value="3"/>           <!-- aninhamento <= 3 -->
    </module>
    <module name="NestedTryDepth">
      <property name="max" value="2"/>
    </module>
    <module name="CyclomaticComplexity">
      <property name="max" value="12"/>
    </module>
    <!-- Erros / boas praticas -->
    <module name="EmptyCatchBlock"/>             <!-- nao engolir excecao -->
    <module name="MagicNumber"/>
    <module name="IllegalCatch"/>                <!-- evita catch(Exception) generico -->
    <!-- Nomes -->
    <module name="TypeName"/>                    <!-- PascalCase -->
    <module name="MethodName"/>                  <!-- camelCase -->
    <module name="ConstantName"/>               <!-- UPPER_SNAKE_CASE -->
    <!-- Logger em vez de System.out -->
    <module name="RegexpSinglelineJava">
      <property name="format" value="System\.(out|err)\.print"/>
      <property name="message" value="Use logger (SLF4J), nao System.out/err — ver obs-logs."/>
    </module>
  </module>
</module>
